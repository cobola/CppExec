# CppExec Environment Configuration
# Copy this file to .env and modify the values

# API Key for authentication (required for production)
API_KEY='your-secret-api-key-here'

# Remote server configuration (for deployment script)
CPPEXEC_SERVER="user@your-server.com"
CPPEXEC_REMOTE_DIR="/opt/cppexec"
CPPEXEC_PORT="4002"
